# BioCheck platform — local configuration template.
# Copy to .env.local and fill in. NEVER commit real values.

# --- Database (choose one) ---
# Production/staging: PostgreSQL connection string.
DATABASE_URL=postgres://biocheck:CHANGE_ME@localhost:5432/biocheck
# Development only: in-process PGlite (no server needed). Uncomment to use.
# DB_DRIVER=pglite

# --- Secrets ---
# Salt for privacy-minimised IP hashing in sessions/audit (any long random string).
IP_HASH_SALT=CHANGE_ME_RANDOM

# --- verify-core (Python biocheck_engine service) ---
# The platform never talks to the inference sidecar directly.
VERIFY_CORE_URL=https://verify-core.internal.example
# 32-byte urlsafe base64 master key for verify-core (DEV ONLY — production uses KMS/HSM, see docs/ARCHITECTURE.md)
# BIOCHECK_MASTER_KEY_B64=

# --- Environment ---
NODE_ENV=development
