# BioCheck pilot-only configuration. Controlled, consented, NON-PRODUCTION.
# Copy to pilot.env on the isolated pilot host. Never point this at real
# production data or real customers.

APP_ENV=staging                 # hardened config gate; NOT 'production'
BIOCHECK_PILOT_MODE=true         # pilot banner + write-restricted to test tenants

# Database — a dedicated pilot database, wiped after the pilot report is signed.
DATABASE_URL=postgres://biocheck:CHANGE_ME@pilot-db.internal:5432/biocheck_pilot
REDIS_URL=redis://pilot-redis.internal:6379
IP_HASH_SALT=CHANGE_ME_RANDOM_PILOT_SALT

# verify-core + SeetaFace6 sidecar — built on the isolated Linux builder,
# private network only, model hashes registered in a TEST-ONLY registry.
VERIFY_CORE_URL=https://verify-core.pilot.internal
VERIFY_CORE_API_KEY=CHANGE_ME_PILOT_KEY

# KMS — a pilot key in the real KMS/HSM (still no env master key).
# BIOCHECK_MASTER_KEY_B64 must NOT be set.

# Retention — zero capture-media retention; results metadata only (per protocol).
PILOT_EVIDENCE_RETENTION=none

# Only pseudonymised participant codes are recorded. Signed consents live with
# the test lead, OUTSIDE this system. Do not ingest real biometric datasets.
